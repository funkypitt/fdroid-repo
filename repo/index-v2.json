ueTracker": "https://github.com/funkypitt/tankwars-mobile/issues", "lastUpdated": 1775035223000, "license": "MIT", "sourceCode": "https://github.com/funkypitt/tankwars-mobile", "webSite": "https://github.com/funkypitt/tankwars-mobile", "authorName": "funkypitt", "name": {"en-US": "Tank Wars Mobile"}, "summary": {"en-US": "Classic artillery game rebuilt for mobile. 2-player local and online."}, "description": {"en-US": "Tank Wars Mobile is a faithful recreation of the classic DOS artillery game\nTank Wars 3.2 (1992) by Kenneth Morse, rebuilt from the ground up for mobile\ntouchscreens.\n\nTwo players take turns aiming their tanks and firing an arsenal of weapons at\neach other across randomly generated destructible terrain. Judge the angle,\npower, and wind to land your shots — there's no trajectory preview, so every\nshot is a test of skill and intuition.\n\n16 weapons including nukes, MIRVs, lasers, and chain reaction inducers.\n3 defense systems: shields, inertia dampeners, and repulsers.\n6 wall types, 5 wind levels, destructible terrain with crumbling.\nLocal 2-player hot-seat and online multiplayer via Firebase.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n"}, "preferredSigner": "dd7e16bf9c9cd5b2a74160a39a12ce41775243e3d5b8b9bca5585ac4050f245e"}, "versions": {"21ed51750e14ce1ff9b1349a1c214eb6d48198e73b62ef35b0fd0990c525ab5f": {"added": 1775035223000, "file": {"name": "/TankWars-v1.1.0.apk", "sha256": "21ed51750e14ce1ff9b1349a1c214eb6d48198e73b62ef35b0fd0990c525ab5f", "size": 3435850}, "manifest": {"versionName": "1.1.0", "versionCode": 110, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["dd7e16bf9c9cd5b2a74160a39a12ce41775243e3d5b8b9bca5585ac4050f245e"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.tankwars.mobile.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "bf94571ef465278e4af93f78868241a9f68890224526ef513bab2837d43e1d9c": {"added": 1775030525000, "file": {"name": "/TankWa