 "lastUpdated": 1775292540000, "license": "MIT", "sourceCode": "https://github.com/funkypitt/local-2p-games", "webSite": "https://github.com/funkypitt/local-2p-games", "authorName": "funkypitt", "name": {"en-US": "2P Games"}, "summary": {"en-US": "16 multiplayer games — play locally or online. No ads, no accounts."}, "description": {"en-US": "2P Games is a collection of 16 touch-friendly multiplayer games for two\nplayers. Play locally on one device or online with a friend. No accounts,\nno ads.\n\n7 turn-based games support online play via room codes or quick match:\n4 in a Row, Caro, Awalé, Memory, Mastermonde, Tank Wars, Ship Battle.\n\nAlso includes Tennis (with power-ups), Pool, Snakes, Air Hockey, Mini Golf,\nStar Clash, Munch Maze, Wheel of Funktune, Pixel Run, and Horse Jump.\n\nAll games feature intuitive touch controls. Built-in calming background\nmusic with toggle. Every game has rematch support.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n"}, "preferredSigner": "31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"}, "versions": {"fd3047a43b1cdf8ee09e4cd208550edf8c2ceaa6ab6700eed7b630d7b3912691": {"added": 1775292540000, "file": {"name": "/2P-Games-v1.3.0.apk", "sha256": "fd3047a43b1cdf8ee09e4cd208550edf8c2ceaa6ab6700eed7b630d7b3912691", "size": 3242576}, "manifest": {"versionName": "1.3", "versionCode": 4, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "b51aa2c57845a6230df6b2cc40d1eb751100044c9b0821d7ccd32b773c254209": {"added": 1775288192000, "file": {"name": "/2P-Games-v1.2.0.apk", "sha256": "b51aa2c57845a6230df6b2cc40d1eb751100044c9b0821d7ccd32b773c254209", "size": 3242576}, "manifest": {"versionName": "1.2", "versionCode": 3, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 3