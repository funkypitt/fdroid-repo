{"repo": {"timestamp": 1779301150000}, "packages": {"com.local2p.games": {"metadata": {"lastUpdated": 1779301150000, "description": {"en-US": "2P Games is a collection of 16 touch-friendly multiplayer games for two\nplayers. Play locally on one device or online with a friend. No accounts,\nno ads.\n\n8 games support online play via room codes or quick match:\n4 in a Row, Caro, Awalé, Memory, Duck-Day Chess, Tank Wars,\nWord Clash, and Reversi.\n\nAlso includes Tennis (with power-ups), Pool, Carrom, Air Hockey,\nMini Golf, Star Clash, Hangman, and Horse Jump.\n\nEach game has built-in instructions accessible via the ? button.\n\nAll games feature intuitive touch controls. Built-in calming background\nmusic with toggle. Every game has rematch support.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n"}}, "versions": {"a925232b16b5d4931c712906022cf359d45249514e829f7773b85377119dbe39": {"added": 1779301150000, "file": {"name": "/2P-Games-v1.31.0.apk", "sha256": "a925232b16b5d4931c712906022cf359d45249514e829f7773b85377119dbe39", "size": 4028461}, "manifest": {"versionName": "1.31", "versionCode": 34, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "21ab2023181f3b255e8514853c917e7f501fd944904d95214f7970efed898db7": {"added": 1779298564000, "file": {"name": "/2P-Games-v1.30.0.apk", "sha256": "21ab2023181f3b255e8514853c917e7f501fd944904d95214f7970efed898db7", "size": 4027997}, "manifest": {"versionName": "1.30", "versionCode": 33, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "184822d6901