{"repo": {"timestamp": 1777474614000}, "packages": {"com.local2p.games": {"metadata": {"lastUpdated": 1777474614000, "description": {"en-US": "2P Games is a collection of 16 touch-friendly multiplayer games for two\nplayers. Play locally on one device or online with a friend. No accounts,\nno ads.\n\n10 games support online play via room codes or quick match:\n4 in a Row, Caro, Awalé, Memory, Duck-Day Chess, Tank Wars, Ship Battle,\nDots & Boxes, Word Clash, and Tic Tac Toe.\n\nAlso includes Tennis (with power-ups), Pool, Word Clash, Air Hockey, Mini Golf,\nStar Clash, Wheel of Funktune, and Horse Jump.\n\nEach game has built-in instructions accessible via the ? button.\n\nAll games feature intuitive touch controls. Built-in calming background\nmusic with toggle. Every game has rematch support.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n"}}, "versions": {"36cd6116a98392d51686fb07b54622c62908140f877b1995a8375786540410f9": {"added": 1777474614000, "file": {"name": "/2P-Games-v1.15.0.apk", "sha256": "36cd6116a98392d51686fb07b54622c62908140f877b1995a8375786540410f9", "size": 3262996}, "manifest": {"versionName": "1.15.0", "versionCode": 18, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "4504b15501418260e95f417553f3a4ffefc3a05092dbe24e764a0f1de907a601": {"added": 1777461753000, "file": {"name": "/2P-Games-v1.14.1.apk", "sha256": "4504b15501418260e95f417553f3a4ffefc3a05092dbe24e764a0f1de907a601", "size": 3256996}, "manifest": {"versionName": "1.14.1", "versionCode": 17, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_R