{"repo": {"timestamp": 1780057043000}, "packages": {"com.local2p.games": {"metadata": {"lastUpdated": 1780057043000, "description": {"en-US": "2P Games is a collection of 16 touch-friendly multiplayer games for two\nplayers. Play locally on one device or online with a friend. No accounts,\nno ads.\n\n8 games support online play via room codes or quick match:\n4 in a Row, Caro, Awalé, Memory, Duck-Day Chess, Tank Wars,\nWord Clash, and Reversi.\n\nAlso includes Tennis (with power-ups), Pool, Carrom, Air Hockey,\nMini Golf, Star Clash, Hangman, and Horse Jump.\n\nEach game has built-in instructions accessible via the ? button.\n\nAll games feature intuitive touch controls. Built-in calming background\nmusic with toggle. Every game has rematch support.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n"}}, "versions": {"9d89e4f7e53a634918004cf26015a9aeeb2158a38d7c98887f78a1dfcac56249": {"added": 1780057043000, "file": {"name": "/2P-Games-v1.34.0.apk", "sha256": "9d89e4f7e53a634918004cf26015a9aeeb2158a38d7c98887f78a1dfcac56249", "size": 4030221}, "manifest": {"versionName": "1.34", "versionCode": 37, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "2e92e57a8898dffd94d2fede42631302bc4bcaa76cfe3809d32ca8bfe74df7b0": {"added": 1779303881000, "file": {"name": "/2P-Games-v1.33.0.apk", "sha256": "2e92e57a8898dffd94d2fede42631302bc4bcaa76cfe3809d32ca8bfe74df7b0", "size": 4030205}, "manifest": {"versionName": "1.33", "versionCode": 36, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "4bfa346153a