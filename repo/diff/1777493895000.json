{"repo": {"timestamp": 1779274467000}, "packages": {"com.boxbreathing.app": {"metadata": {"name": {"en-US": "Box Breathing 4min"}}, "versions": {"d70965555b4fb197d3d4ca8f188a0e38567fd28b6f486f44a8103cc876d0bf44": null, "6dd1bcb9c1b7605d8b79c39fe8c9cff3658382375b6b1added77bbc4c56553bf": {"added": 1775291348000, "file": {"name": "/box-breathing.apk", "sha256": "6dd1bcb9c1b7605d8b79c39fe8c9cff3658382375b6b1added77bbc4c56553bf", "size": 80549863}, "manifest": {"nativecode": ["arm64-v8a", "armeabi-v7a", "x86", "x86_64"], "versionName": "1.1.0", "versionCode": 2, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["fac61745dc0903786fb9ede62a962b399f7348f0bb6f899b8332667591033b9c"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "android.permission.READ_EXTERNAL_STORAGE"}, {"name": "android.permission.SYSTEM_ALERT_WINDOW"}, {"name": "android.permission.VIBRATE"}, {"name": "android.permission.WRITE_EXTERNAL_STORAGE"}, {"name": "com.boxbreathing.app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}}}, "com.freedomfighter.jeuxdujour": {"metadata": {"added": 1777913639000, "categories": ["Games"], "issueTracker": "https://github.com/funkypitt/jeux-du-jour/issues", "lastUpdated": 1778228733000, "license": "MIT", "sourceCode": "https://github.com/funkypitt/jeux-du-jour", "webSite": "https://github.com/funkypitt/jeux-du-jour", "authorName": "funkypitt", "name": {"en-US": "Jeux du Jour"}, "summary": {"en-US": "French daily word games — Le Mot, L'Hexagone, Connexions. Offline, no ads."}, "description": {"en-US": "Jeux du Jour is a collection of three French daily word games inspired by\nthe New York Times puzzle games. Every player gets the same puzzle on the\nsame day, generated deterministically from a date-based seed — no server\nneeded.\n\nLe Mot (Wordle): Guess the 5-letter French word in 6 tries. Color-coded\nfeedback helps narrow down the answer.\n\nL'Hexagone (Spelling Bee): Form as many words as possible using 7 letters\narranged in a hexagonal grid. Every word must include the center letter.\nClimb from Débutant to Génie.\n\nConnexions (Connections): Sort 16 words into four groups of four that share\na hidden connection. Four difficulty levels from yellow (easy) to purple\n(tricky).\n\nDictionary powered by Lexique383 from lexique.org (109,000+ French words).\n30 hand-curated Connexions puzzles included.\n\nFree and open source. No ads. No tracking. No accounts. Works fully offline.\n"}, "preferredSigner": "1a88ba1d6efc3e693fe4f3a1c2b5c25265ed103f43d37bc91e4e590530180811"}, "versions": {"b463e2d15b06d311bf0bf853de05bbec4e31c2161ad2c4c157ead07e3192022b": {"added": 1778228733000, "file": {"name": "/jeux-du-jour.apk", "sha256": "b463e2d15b06d311bf0bf853de05bbec4e31c2161ad2c4c157ead07e3192022b", "size": 7736306}, "manifest": {"nativecode": ["arm64-v8a", "armeabi-v7a", "x86", "x86_64"], "versionName": "1.1.0", "versionCode": 2, "usesSdk": {"minSdkVersion": 26, "targetSdkVersion": 34}, "signer": {"sha256": ["1a88ba1d6efc3e693fe4f3a1c2b5c25265ed103f43d37bc91e4e590530180811"]}, "usesPermission": [{"name": "com.freedomfighter.jeuxdujour.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "62e21ceead36c63b01c3aa1d10cc2fd009fb625d474515b1b4ca8711b6da94b4": {"added": 1777913639000, "file": {"name": "/Jeux-du-Jour-v1.0.0.apk", "sha256": "62e21ceead36c63b01c3aa1d10cc2fd009fb625d474515b1b4ca8711b6da94b4", "size": 24027002}, "manifest": {"nativecode": ["arm64-v8a", "armeabi-v7a", "x86", "x86_64"], "versionName": "1.0", "versionCode": 1, "usesSdk": {"minSdkVersion": 26, "targetSdkVersion": 34}, "signer": {"sha256": ["9b6ae69650b1ccf5bfa08ad15dc8b412622b8e5a3202ea066215067897a2be28"]}, "usesPermission": [{"name": "com.freedomfighter.jeuxdujour.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}}}, "com.local2p.games": {"metadata": {"lastUpdated": 1779274466000, "description": {"en-US": "2P Games is a collection of 16 touch-friendly multiplayer games for two\nplayers. Play locally on one device or online with a friend. No accounts,\nno ads.\n\n10 games support online play via room codes or quick match:\n4 in a Row, Caro, Awalé, Memory, Duck-Day Chess, Tank Wars, Ship Battle,\nDots & Boxes, Word Clash, and Tic Tac Toe.\n\nAlso includes Tennis (with power-ups), Pool, Air Hockey, Mini Golf,\nStar Clash, Hangman, and Horse Jump.\n\nEach game has built-in instructions accessible via the ? button.\n\nAll games feature intuitive touch controls. Built-in calming background\nmusic with toggle. Every game has rematch support.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n"}}, "versions": {"cf7313d771c5365be77685e2a666d2c262fe226528798ac7fef17ddfa4b33aea": {"added": 1779274466000, "file": {"name": "/2P-Games-v1.27.0.apk", "sha256": "cf7313d771c5365be77685e2a666d2c262fe226528798ac7fef17ddfa4b33aea", "size": 4025721}, "manifest": {"versionName": "1.27", "versionCode": 30, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "794067e80c6d46eae5b3f48fca93ab37785785b57b26a6a3f944394d50a60795": {"added": 1778228732000, "file": {"name": "/2P-Games-v1.26.0.apk", "sha256": "794067e80c6d46eae5b3f48fca93ab37785785b57b26a6a3f944394d50a60795", "size": 4025745}, "manifest": {"versionName": "1.26", "versionCode": 29, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "acb14348067c0adc192932643df92204364d5d1e274f3fca5a5a6de0de659e0c": {"added": 1777913638000, "file": {"name": "/2P-Games-v1.25.0.apk", "sha256": "acb14348067c0adc192932643df92204364d5d1e274f3fca5a5a6de0de659e0c", "size": 4026289}, "manifest": {"versionName": "1