", "versionCode": 21, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "a4df0d10399cc241bee3ffe81cc494c97f81816eef50f0ebb3514a54fad15cb0": {"added": 1777531067000, "file": {"name": "/2P-Games-v1.17.0.apk", "sha256": "a4df0d10399cc241bee3ffe81cc494c97f81816eef50f0ebb3514a54fad15cb0", "size": 3263344}, "manifest": {"versionName": "1.17", "versionCode": 20, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "75493651fec3a8844f1d87208505cbd77a9abb5b7ab99e095d166bbfc1284b3e": {"added": 1777493927000}, "36cd6116a98392d51686fb07b54622c62908140f877b1995a8375786540410f9": {"added": 1777474614000, "file": {"name": "/2P-Games-v1.15.0.apk", "sha256": "36cd6116a98392d51686fb07b54622c62908140f877b1995a8375786540410f9", "size": 3262996}, "manifest": {"versionName": "1.15.0", "versionCode": 18, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}}}, "ua.acclorite.book_story.debug": {"metadata": {"added": 1778230182000, "categories": ["Reading"], "lastUpdated": 1778230182000, "license": "GPL-3.0-only", "authorName": "funkypitt", "name": {"en-US": "ePub Magazine reader"}, "summary": {"en-US": "ePub reader tuned for daily newspaper / magazine issues"}, "description": {"en-US": "Fork of Book's Story (ua.acclorite.book_story) with an opinionated\nmagazine-mode parser and TOC for ePub issues produced by the in-house\nnewsletter generator (NZZ, 24 heures, Courrier International, Economist\nfixtures).\n\nDetects magazine ePubs at open time, paginates the table of contents\nwith one card per article (category, title, optional cover image),\nand routes tap → article view rendered by an in-zip WebView.\n\nA permanent three-zone navigation header (prev / home / next) sits on\ntop of the existing tap-zone gesture system on every magazine screen.\n\nDebug-signed; sideload only. Coexists with upstream Book's Story\nrelease thanks to the .debug application id suffix.\n"}, "icon": {"en-US": {"name": "/icons/ua.acclorite.book_story.debug.15.png", "sha256": "a24b00cf1b9da1353bb8a5d5a450944c6f4aaed40bb90bfd0ff4f49680db9578", "size": 1584}}, "preferredSigner": "9b6ae69650b1ccf5bfa08ad15dc8b412622b8e5a3202ea066215067897a2be28"}, "versions": {"4de2fafea0d080265daeeff2ef51fe299d2d2b0bd8f48bc55c982a31c379e451": {"added": 1778230182000, "file": {"name": "/MagazineReader-v0.2.0-magazine-debug.apk", "sha256": "4de2fafea0d080265daeeff2ef51fe299d2d2b0bd8f48bc55c982a31c379e451", "size": 47708611}, "manifest": {"nativecode": ["arm64-v8a", "armeabi-v7a", "x86", "x86_64"], "versionName": "0.2.0-magazine", "versionCode": 15, "usesSdk": {"minSdkVersion": 26, "targetSdkVersion": 36}, "signer": {"sha256": ["9b6ae69650b1ccf5bfa08ad15dc8b412622b8e5a3202ea066215067897a2be28"]}}}}}}}