{"repo": {"timestamp": 1780233268000, "categories": {"Multimedia": {"name": {"en-US": "Multimedia"}}}}, "packages": {"app.sobre.player": {"metadata": {"added": 1780233268000, "categories": ["Multimedia", "Internet"], "lastUpdated": 1780233268000, "license": "GPL-3.0-only", "sourceCode": "https://github.com/funkypitt/sobre", "webSite": "https://github.com/funkypitt/sobre", "authorName": "funkypitt", "name": {"en-US": "Sobre"}, "summary": {"en-US": "Audio-only YouTube subscription player, 100% text"}, "description": {"en-US": "Sobre is an anti-brainrot audio player for YouTube subscriptions.\nIt plays only the audio from channels you explicitly follow —\nno video, no thumbnails, no algorithmic recommendations, no Shorts,\nno comments, no infinite scroll.\n\nThe interface is 100% text: no images, no icons, no avatars.\nSubscribe by pasting a channel or video URL, or by sharing directly\nfrom the YouTube app.\n\nFeatures:\n* Audio-only playback with background and lock screen support\n* Subscribe to channels via URL paste or Android share intent\n* Chronological feed — no algorithm, no recommendations\n* Episode chapters and full descriptions\n* Adjustable playback speed (0.75x to 2x)\n* Download episodes for offline listening\n* Periodic RSS-based feed refresh\n* High-contrast text UI, e-ink friendly\n* Fully local, no accounts, no tracking\n\nBuilt with NewPipeExtractor (GPLv3). Not affiliated with YouTube.\n"}, "icon": {"en-US": {"name": "/app.sobre.player/en-US/icon_ew3SUl5du8UtzHC9f30NkVRIyRN0nqt_gzW6-1fUE14=.png", "sha256": "7b0dd2525e5dbbc52dcc70bd7f7d0d915448c913749eab7f8335bafb57d4135e", "size": 4460}}, "preferredSigner": "9b6ae69650b1ccf5bfa08ad15dc8b412622b8e5a3202ea066215067897a2be28"}, "versions": {"ada3b9c1eecdfe8f70492cec59283f02bd8791a6f3e703207827346f56d7ee2e": {"added": 1780233268000, "file": {"name": "/Sobre-v0.1.0.apk", "sha256": "ada3b9c1eecdfe8f70492cec59283f02bd8791a6f3e703207827346f56d7ee2e", "size": 11063762}, "manifest": {"nativecode": ["arm64-