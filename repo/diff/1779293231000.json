{"repo": {"timestamp": 1780236949000, "categories": {"Multimedia": {"name": {"en-US": "Multimedia"}}}}, "packages": {"app.sobre.player": {"metadata": {"added": 1780233268000, "categories": ["Multimedia", "Internet"], "lastUpdated": 1780233268000, "license": "GPL-3.0-only", "sourceCode": "https://github.com/funkypitt/sobre", "webSite": "https://github.com/funkypitt/sobre", "authorName": "funkypitt", "name": {"en-US": "Sobre"}, "summary": {"en-US": "Audio-only YouTube subscription player, 100% text"}, "description": {"en-US": "Sobre is an anti-brainrot audio player for YouTube subscriptions.\nIt plays only the audio from channels you explicitly follow —\nno video, no thumbnails, no algorithmic recommendations, no Shorts,\nno comments, no infinite scroll.\n\nThe interface is 100% text: no images, no icons, no avatars.\nSubscribe by pasting a channel or video URL, or by sharing directly\nfrom the YouTube app.\n\nFeatures:\n* Audio-only playback with background and lock screen support\n* Subscribe to channels via URL paste or Android share intent\n* Chronological feed — no algorithm, no recommendations\n* Episode chapters and full descriptions\n* Adjustable playback speed (0.75x to 2x)\n* Download episodes for offline listening\n* Periodic RSS-based feed refresh\n* High-contrast text UI, e-ink friendly\n* Fully local, no accounts, no tracking\n\nBuilt with NewPipeExtractor (GPLv3). Not affiliated with YouTube.\n"}, "icon": {"en-US": {"name": "/app.sobre.player/en-US/icon_ew3SUl5du8UtzHC9f30NkVRIyRN0nqt_gzW6-1fUE14=.png", "sha256": "7b0dd2525e5dbbc52dcc70bd7f7d0d915448c913749eab7f8335bafb57d4135e", "size": 4460}}, "preferredSigner": "9b6ae69650b1ccf5bfa08ad15dc8b412622b8e5a3202ea066215067897a2be28"}, "versions": {"bd7e75f3e47bde3a3bfe5e7c6d6d9116acc9fa1bc1c3e5da75dfe226beb3efe3": {"added": 1780233268000, "file": {"name": "/Sobre-v0.1.0.apk", "sha256": "bd7e75f3e47bde3a3bfe5e7c6d6d9116acc9fa1bc1c3e5da75dfe226beb3efe3", "size": 11549279}, "manifest": {"nativecode": ["arm64-v8a", "armeabi-v7a", "x86", "x86_64"], "versionName": "0.1.0", "versionCode": 1, "usesSdk": {"minSdkVersion": 26, "targetSdkVersion": 35}, "signer": {"sha256": ["9b6ae69650b1ccf5bfa08ad15dc8b412622b8e5a3202ea066215067897a2be28"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "android.permission.ACCESS_NETWORK_STATE"}, {"name": "android.permission.FOREGROUND_SERVICE"}, {"name": "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"}, {"name": "android.permission.POST_NOTIFICATIONS"}, {"name": "android.permission.WAKE_LOCK"}, {"name": "android.permission.RECEIVE_BOOT_COMPLETED"}, {"name": "app.sobre.player.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}}}, "com.local2p.games": {"metadata": {"lastUpdated": 1780057043000, "description": {"en-US": "2P Games is a collection of 16 touch-friendly multiplayer games for two\nplayers. Play locally on one device or online with a friend. No accounts,\nno ads.\n\n8 games support online play via room codes or quick match:\n4 in a Row, Caro, Awalé, Memory, Duck-Day Chess, Tank Wars,\nWord Clash, and Reversi.\n\nAlso includes Tennis (with power-ups), Pool, Carrom, Air Hockey,\nMini Golf, Star Clash, Hangman, and Horse Jump.\n\nEach game has built-in instructions accessible via the ? button.\n\nAll games feature intuitive touch controls. Built-in calming background\nmusic with toggle. Every game has rematch support.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n"}}, "versions": {"9d89e4f7e53a634918004cf26015a9aeeb2158a38d7c98887f78a1dfcac56249": {"added": 1780057043000, "file": {"name": "/2P-Games-v1.34.0.apk", "sha256": "9d89e4f7e53a634918004cf26015a9aeeb2158a38d7c98887f78a1dfcac56249", "size": 4030221}, "manifest": {"versionName": "1.34", "versionCode": 37, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.gam