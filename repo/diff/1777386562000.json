{"repo": {"timestamp": 1777913639000}, "packages": {"com.freedomfighter.jeuxdujour": {"metadata": {"added": 1777913639000, "categories": ["Games"], "issueTracker": "https://github.com/funkypitt/jeux-du-jour/issues", "lastUpdated": 1777913639000, "license": "MIT", "sourceCode": "https://github.com/funkypitt/jeux-du-jour", "webSite": "https://github.com/funkypitt/jeux-du-jour", "authorName": "funkypitt", "name": {"en-US": "Jeux du Jour"}, "summary": {"en-US": "French daily word games — Le Mot, L'Hexagone, Connexions. Offline, no ads."}, "description": {"en-US": "Jeux du Jour is a collection of three French daily word games inspired by\nthe New York Times puzzle games. Every player gets the same puzzle on the\nsame day, generated deterministically from a date-based seed — no server\nneeded.\n\nLe Mot (Wordle): Guess the 5-letter French word in 6 tries. Color-coded\nfeedback helps narrow down the answer.\n\nL'Hexagone (Spelling Bee): Form as many words as possible using 7 letters\narranged in a hexagonal grid. Every word must include the center letter.\nClimb from Débutant to Génie.\n\nConnexions (Connections): Sort 16 words into four groups of four that share\na hidden connection. Four difficulty levels from yellow (easy) to purple\n(tricky).\n\nDictionary powered by Lexique383 from lexique.org (109,000+ French words).\n30 hand-curated Connexions puzzles included.\n\nFree and open source. No ads. No tracking. No accounts. Works fully offline.\n"}, "preferredSigner": "9b6ae69650b1ccf5bfa08ad15dc8b412622b8e5a3202ea066215067897a2be28"}, "versions": {"62e21ceead36c63b01c3aa1d10cc2fd009fb625d474515b1b4ca8711b6da94b4": {"added": 1777913639000, "file": {"name": "/Jeux-du-Jour-v1.0.0.apk", "sha256": "62e21ceead36c63b01c3aa1d10cc2fd009fb625d474515b1b4ca8711b6da94b4", "size": 24027002}, "manifest": {"nativecode": ["arm64-v8a", "armeabi-v7a", "x86", "x86_64"], "versionName": "1.0", "versionCode": 1, "usesSdk": {"minSdkVersion": 26, "targetSdkVersion": 34}, "signer": {"sha256": ["9b6ae69650b1ccf5bfa08ad15dc8b412622b8e5a3202ea066215067897a2be28"]}, "usesPermission": [{"name": "com.freedomfighter.jeuxdujour.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}}}, "com.local2p.games": {"metadata": {"lastUpdated": 1777913638000, "description": {"en-US": "2P Games is a collection of 16 touch-friendly multiplayer games for two\nplayers. Play locally on one device or online with a friend. No accounts,\nno ads.\n\n10 games support online play via room codes or quick match:\n4 in a Row, Caro, Awalé, Memory, Duck-Day Chess, Tank Wars, Ship Battle,\nDots & Boxes, Word Clash, and Tic Tac Toe.\n\nAlso includes Tennis (with power-ups), Pool, Word Clash, Air Hockey, Mini Golf,\nStar Clash, Wheel of Funktune, and Horse Jump.\n\nEach game has built-in instructions accessible via the ? button.\n\nAll games feature intuitive touch controls. Built-in calming background\nmusic with toggle. Every game has rematch support.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n"}}, "versions": {"acb14348067c0adc192932643df92204364d5d1e274f3fca5a5a6de0de659e0c": {"added": 1777913638000, "file": {"name": "/2P-Games-v1.25.0.apk", "sha256": "acb14348067c0adc192932643df92204364d5d1e274f3fca5a5a6de0de659e0c", "size": 4026289}, "manifest": {"versionName": "1.25", "versionCode": 28, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876ed7d0e95c3bb73730592"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.local2p.games.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "0043d2d740675a0c50f4e1c224d76d12f48715b088edbc4289976cba84358901": {"added": 1777913638000, "file": {"name": "/2P-Games-v1.24.0.apk", "sha256": "0043d2d740675a0c50f4e1c224d76d12f48715b088edbc4289976cba84358901", "size": 4025637}, "manifest": {"versionName": "1.24", "versionCode": 27, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["31aa0828a61c83d171833002cf5caacdf29863639876e