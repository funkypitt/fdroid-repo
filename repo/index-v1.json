{"repo": {"timestamp": 1777452037000, "version": 20002, "name": "funkypitt's F-Droid Repo", "icon": "icon.png", "address": "https://funkypitt.github.io/fdroid-repo/repo", "description": "Personal F-Droid repository with custom apps: Pluralis (alternative news aggregator) and OpenLibe Extended (e-ink library client)."}, "requests": {"install": [], "uninstall": []}, "apps": [{"authorName": "funkypitt", "categories": ["Games"], "suggestedVersionCode": "2147483647", "description": "2P Games is a collection of 16 touch-friendly multiplayer games for two\nplayers. Play locally on one device or online with a friend. No accounts,\nno ads.\n\n10 games support online play via room codes or quick match:\n4 in a Row, Caro, Awal\u00e9, Memory, Bulls & Cows, Tank Wars, Ship Battle,\nDots & Boxes, Word Clash, and Tic Tac Toe.\n\nAlso includes Tennis (with power-ups), Pool, Word Clash, Air Hockey, Mini Golf,\nStar Clash, Wheel of Funktune, and Horse Jump.\n\nEach game has built-in instructions accessible via the ? button.\n\nAll games feature intuitive touch controls. Built-in calming background\nmusic with toggle. Every game has rematch support.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n", "issueTracker": "https://github.com/funkypitt/local-2p-games/issues", "license": "MIT", "name": "2P Games", "sourceCode": "https://github.com/funkypitt/local-2p-games", "summary": "16 multiplayer games \u2014 play locally or online. No ads, no accounts.", "webSite": "https://github.com/funkypitt/local-2p-games", "added": 1775056773000, "packageName": "com.local2p.games", "lastUpdated": 1777452037000}, {"authorName": "funkypitt", "categories": ["Sports & Health"], "suggestedVersionCode": "2147483647", "description": "A calming, distraction-free breathing exercise app. Follow the\nanimated guide around a square: breathe in, hold, breathe out, hold.\nThe 4-minute session starts with a 3-second rhythm and gently\ntransitions to 4 seconds halfway through. Bilingual instructions\n(English / French). No accounts, no ads, no tracking.\n", "issueTracker": "https://github.com/funkypitt/box-breathing/issues", "license": "GPL-3.0-only", "name": "Box Breathing", "sourceCode": "https://github.com/funkypitt/box-breathing", "summary": "Minimalist 4-minute guided box breathing exercise", "webSite": "https://github.com/funkypitt/box-breathing", "added": 1775291348000, "packageName": "com.boxbreathing.app", "lastUpdated": 1775291348000}, {"authorName": "funkypitt", "categories": ["Reading"], "suggestedVersionCode": "2147483647", "description": "Le dictionnaire de la langue fran\\xE7aise d'\\xC9mile Littr\\xE9,\ncomplet et enti\\xE8rement gratuit, consultable hors-ligne.\n78 599 entr\\xE9es avec d\\xE9finitions, \\xE9tymologies et citations.\nRecherche instantan\\xE9e, mot du jour, favoris, renvois crois\\xE9s\ncliquables, mode sombre. Aucune connexion internet requise.\nDonn\\xE9es lexicographiques sous licence CC BY-SA 3.0\n(Fran\\xE7ois Gannaz, littre.org).\n", "issueTracker": "https://github.com/funkypitt/littre-app/issues", "license": "GPL-3.0-only", "name": "Le dictionnaire Littr\u00e9", "sourceCode": "https://github.com/funkypitt/littre-app", "summary": "Dictionnaire Littr\u00e9 complet, gratuit et hors-ligne", "webSite": "https://github.com/funkypitt/littre-app", "added": 1774267469000, "packageName": "ch.littre.littre_app", "lastUpdated": 1774267469000}, {"authorName": "funkypitt", "categories": ["Reading"], "suggestedVersionCode": "2147483647", "description": "Open-source e-book reader optimized for e-ink displays. Paginated\nEPUB reading with adaptive font sizing, high-contrast themes, and\ntap zones designed for e-paper. Search and download from online\nlibrary catalogs. Local library management.\nThis application is a reading tool. It does not host any content.\nUsers are solely responsible for compliance with copyright laws\nin their jurisdiction.\n", "issueTracker": "https://github.com/funkypitt/funky-openlib/issues", "license": "AGPL-3.0-only", "name": "OpenLibe e-Ink Remix", "sourceCode": "https://github.com/funkypitt/funky-openlib", "summary": "E-ink optimized e-book reader and library browser", "webSite": "https://github.com/funkypitt/funky-openlib", "added": 1774210436000, "packageName": "dev.wath.openlibeextendedeinkremix", "lastUpdated": 1774210436000}, {"authorName": "funkypitt", "categories": ["Reading", "Internet"], "suggestedVersionCode": "2147483647", "description": "Lightweight RSS/Atom feed reader with a paginated reading mode\noptimized for e-ink displays. Serif typography, adaptive font sizing,\ntap zones for page turns. Bookmarks, OPML import/export, paid\nSubstack support via cookie authentication.\nNo accounts, no tracking \u2014 fully local and offline-capable.\n", "issueTracker": "https://github.com/funkypitt/pluralis/issues", "license": "GPL-3.0-only", "name": "Pluralis", "sourceCode": "https://github.com/funkypitt/pluralis", "summary": "E-ink friendly RSS/Atom reader for Android", "webSite": "https://github.com/funkypitt/pluralis", "added": 1774210436000, "packageName": "com.pluralis.pluralis", "lastUpdated": 1774210436000}, {"authorName": "funkypitt", "categories": ["Games"], "suggestedVersionCode": "2147483647", "description": "Tank Wars Mobile is a faithful recreation of the classic DOS artillery game\nTank Wars 3.2 (1992) by Kenneth Morse, rebuilt from the ground up for mobile\ntouchscreens.\n\nTwo players take turns aiming their tanks and firing an arsenal of weapons at\neach other across randomly generated destructible terrain. Judge the angle,\npower, and wind to land your shots \u2014 there's no trajectory preview, so every\nshot is a test of skill and intuition.\n\n16 weapons including nukes, MIRVs, lasers, and chain reaction inducers.\n3 defense systems: shields, inertia dampeners, and repulsers.\n6 wall types, 5 wind levels, destructible terrain with crumbling.\nLocal 2-player hot-seat and online multiplayer via Firebase.\n\nFree and open source. No ads. No tracking. No in-app purchases.\n", "issueTracker": "https://github.com/funkypitt/tankwars-mobile/issues", "license": "MIT", "name": "Tank Wars Mobile", "sourceCode": "https://github.com/funkypitt/tankwars-mobile", "summary": "Classic artillery game rebuilt for mobile. 2-player local and online.", "webSite": "https://github.com/funkypitt/tankwars-mobile", "added": 1775030525000, "packageName": "com.tankwars.mobile", "lastUpdated": 1775035223000}], "packages": {"ch.littre.littre_app": [{"added": 1774267469000, "apkName": "littre-arm64.apk", "hash": "4d01ac1338caf2fdb98a6604389036f9548cc05a487c976c877d3f1096589a91", "hashType": "sha256", "minSdkVersion": 24, "nativecode": ["arm64-v8a"], "packageName": "ch.littre.littre_app", "sig": "a68c2003a134da7235605d8da889d3dc", "signer": "9b6ae69650b1ccf5bfa08ad15dc8b412622b8e5a3202ea066215067897a2be28", "size": 83725740, "targetSdkVersion": 36, "uses-permission": [["ch.littre.littre_app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION", null]], "versionCode": 2001, "versionName": "1.0.0"}], "com.boxbreathing.app": [{"added": 1775291348000, "apkName": "box-breathing.apk", "hash": "d70965555b4fb197d3d4ca8f188a0e38567fd28b6f486f44a8103cc876d0bf44", "hashType": "sha256", "minSdkVersion": 24, "nativecode": ["arm64-v8a", "armeabi-v7a", "x86", "x86_64"], "packageName": "com.boxbreathing.app", "sig": "b6e0344e9cbcbcd6f20dc82b513925f6", "signer": "fac61745dc0903786fb9ede62a962b399f7348f0bb6f899b8332667591033b9c", "size": 80558903, "targetSdkVersion": 36, "uses-permission": [["android.permission.INTERNET", null], ["android.permission.READ_EXTERNAL_STORAGE", null], ["android.permission.SYSTEM_ALERT_WINDOW", null], ["android.permission.VIBRATE", null], ["android.permission.WRITE_EXTERNAL_STORAGE", null], ["com.boxbreathing.app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION", null]], "versionCode": 2, "versionName": "1.1.0"}], "com.local2p.games": [{"added": 1777452037000, "apkName": "2P-Games-v1.13.0.apk", "hash": "37a52c3360daba74221377a1c77ae47f3fbe99aa28a2