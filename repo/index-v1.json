{"repo": {"timestamp": 1774337338000, "version": 20002, "name": "funkypitt's F-Droid Repo", "icon": "icon.png", "address": "https://funkypitt.github.io/fdroid-repo/repo", "description": "Personal F-Droid repository with custom apps: Pluralis (alternative news aggregator) and OpenLibe Extended (e-ink library client)."}, "requests": {"install": [], "uninstall": []}, "apps": [{"authorName": "funkypitt", "categories": ["Multimedia", "Reading"], "suggestedVersionCode": "2147483647", "description": "Application de livres audio pour la Biblioth\u00e8que Sonore Romande\nvia e-bibliomedia. Streaming et t\u00e9l\u00e9chargement, gestion des pr\u00eats\net r\u00e9servations.\n", "issueTracker": "https://github.com/funkypitt/bsr-app/issues", "license": "GPL-3.0-only", "name": "Biblioth\u00e8que Sonore", "sourceCode": "https://github.com/funkypitt/bsr-app", "summary": "App de livres audio pour e-bibliomedia Lausanne", "webSite": "https://github.com/funkypitt/bsr-app", "added": 1774211822000, "icon": "ch.ebibliomedia.bsr.1.png", "packageName": "ch.ebibliomedia.bsr", "lastUpdated": 1774211822000}, {"authorName": "funkypitt", "categories": ["Reading"], "suggestedVersionCode": "2147483647", "description": "Le dictionnaire de la langue fran\\xE7aise d'\\xC9mile Littr\\xE9,\ncomplet et enti\\xE8rement gratuit, consultable hors-ligne.\n78 599 entr\\xE9es avec d\\xE9finitions, \\xE9tymologies et citations.\nRecherche instantan\\xE9e, mot du jour, favoris, renvois crois\\xE9s\ncliquables, mode sombre. Aucune connexion internet requise.\nDonn\\xE9es lexicographiques sous licence CC BY-SA 3.0\n(Fran\\xE7ois Gannaz, littre.org).\n", "issueTracker": "https://github.com/funkypitt/littre-app/issues", "license": "GPL-3.0-only", "name": "Le dictionnaire Littr\u00e9", "sourceCode": "https://github.com/funkypitt/littre-app", "summary": "Dictionnaire Littr\u00e9 complet, gratuit et hors-ligne", "webSite": "https://github.com/funkypitt/littre-app", "added": 1774267469000, "icon": "ch.littre.littre_app.2001.png", "packageName": "ch.littre.littre_app", "lastUpdated": 1774267469000}, {"authorName": "funkypitt", "categories": ["Reading"], "suggestedVersionCode": "2147483647", "description": "Open-source e-book reader optimized for e-ink displays. Paginated\nEPUB reading with adaptive font sizing, high-contrast themes, and\ntap zones designed for e-paper. Search and download from online\nlibrary catalogs. Local library management.\nThis application is a reading tool. It does not host any content.\nUsers are solely responsible for compliance with copyright laws\nin their jurisdiction.\n", "issueTracker": "https://github.com/funkypitt/funky-openlib/issues", "license": "AGPL-3.0-only", "name": "OpenLibe e-Ink Remix", "sourceCode": "https://github.com/funkypitt/funky-openlib", "summary": "E-ink optimized e-book reader and library browser", "webSite": "https://github.com/funkypitt/funky-openlib", "added": 1774210436000, "icon": "dev.wath.openlibeextendedeinkremix.2014.png", "packageName": "dev.wath.openlibeextendedeinkremix", "lastUpdated": 1774210436000}, {"authorName": "funkypitt", "categories": ["Reading", "Internet"], "suggestedVersionCode": "2147483647", "description": "Lightweight RSS/Atom feed reader with a paginated reading mode\noptimized for e-ink displays. Serif typography, adaptive font sizing,\ntap zones for page turns. Bookmarks, OPML import/export, paid\nSubstack support via cookie authentication.\nNo accounts, no tracking \u2014 fully local and offline-capable.\n", "issueTracker": "https://github.com/funkypitt/pluralis/issues", "license": "GPL-3.0-only", "name": "Pluralis", "sourceCode": "https://github.com/funkypitt/pluralis", "summary": "E-ink friendly RSS/Atom reader for Android", "webSite": "https://github.com/funkypitt/pluralis", "added": 1774210436000, "packageName": "com.pluralis.pluralis", "lastUpdated": 1774210436000}], "packages": {"ch.ebibliomedia.bsr": [{"added": 1774211822000, "apkName": "BibliothequeSonore-v0.6.1.apk", "hash": "6761471293bc